{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm ci",
  "framework": "vite",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "^/assets/.*",
      "dest": "/$0"
    },
    {
      "src": "^/(?!api).*\\..*",
      "dest": "/$0"
    },
    {
      "src": "^(?!/api).*",
      "dest": "/index.html"
    }
  ]
}
